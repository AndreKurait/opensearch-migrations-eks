  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "htmlhint": "^1.9.2",
    "linkinator": "^7.6.1",
